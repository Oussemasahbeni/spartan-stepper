{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@spartan-ng/helm/button": ["./src/app/libs/button/src/index.ts"],
      "@spartan-ng/helm/field": ["./src/app/libs/field/src/index.ts"],
      "@spartan-ng/helm/icon": ["./src/app/libs/icon/src/index.ts"],
      "@spartan-ng/helm/input": ["./src/app/libs/input/src/index.ts"],
      "@spartan-ng/helm/utils": ["./src/app/libs/utils/src/index.ts"],
      "@spartan-ng/helm/label": ["./src/app/libs/label/src/index.ts"],
      "@spartan-ng/helm/separator": ["./src/app/libs/separator/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
